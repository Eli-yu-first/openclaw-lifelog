{
  "$schema": "https://docs.openclaw.ai/schemas/openclaw.json",
  "agents": {
    "defaults": {
      "model": "anthropic/claude-sonnet-4-5",
      "memorySearch": {
        "enabled": true,
        "provider": "openai",
        "model": "text-embedding-3-small",
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3
          }
        }
      },
      "subagents": {
        "maxConcurrent": 16,
        "archiveAfterMinutes": 60
      },
      "sandbox": {
        "mode": "docker",
        "image": "openclaw/sandbox:latest"
      }
    },
    "list": [
      {
        "id": "master-habit",
        "default": true,
        "name": "Master Habit Agent",
        "workspace": "~/.openclaw/workspace-master",
        "sandbox": { "mode": "off" },
        "subagents": {
          "allowAgents": [
            "health-fitness",
            "nutrition-diet",
            "sleep-rest",
            "social-communication",
            "entertainment-leisure",
            "learning-education",
            "finance-shopping",
            "home-environment",
            "transportation-travel",
            "personal-care",
            "productivity-focus",
            "emotional-wellness",
            "morning-routine",
            "departure",
            "data-acquisition"
          ]
        },
        "tools": {
          "browser": { "enabled": true },
          "exec": { "enabled": true },
          "camera": { "enabled": true }
        }
      },
      {
        "id": "health-fitness",
        "name": "Health & Fitness Agent",
        "workspace": "~/.openclaw/workspace-health-fitness",
        "model": "anthropic/claude-sonnet-4-5"
      },
      {
        "id": "nutrition-diet",
        "name": "Nutrition & Diet Agent",
        "workspace": "~/.openclaw/workspace-nutrition",
        "model": "anthropic/claude-sonnet-4-5"
      },
      {
        "id": "sleep-rest",
        "name": "Sleep & Rest Agent",
        "workspace": "~/.openclaw/workspace-sleep",
        "model": "anthropic/claude-sonnet-4-5"
      },
      {
        "id": "social-communication",
        "name": "Social & Communication Agent",
        "workspace": "~/.openclaw/workspace-social",
        "model": "anthropic/claude-sonnet-4-5"
      },
      {
        "id": "entertainment-leisure",
        "name": "Entertainment & Leisure Agent",
        "workspace": "~/.openclaw/workspace-entertainment",
        "model": "anthropic/claude-sonnet-4-5"
      },
      {
        "id": "learning-education",
        "name": "Learning & Education Agent",
        "workspace": "~/.openclaw/workspace-learning",
        "model": "anthropic/claude-sonnet-4-5"
      },
      {
        "id": "finance-shopping",
        "name": "Finance & Shopping Agent",
        "workspace": "~/.openclaw/workspace-finance",
        "model": "anthropic/claude-sonnet-4-5"
      },
      {
        "id": "home-environment",
        "name": "Home & Environment Agent",
        "workspace": "~/.openclaw/workspace-home",
        "model": "anthropic/claude-sonnet-4-5"
      },
      {
        "id": "transportation-travel",
        "name": "Transportation & Travel Agent",
        "workspace": "~/.openclaw/workspace-transport",
        "model": "anthropic/claude-sonnet-4-5"
      },
      {
        "id": "personal-care",
        "name": "Personal Care Agent",
        "workspace": "~/.openclaw/workspace-personal",
        "model": "anthropic/claude-sonnet-4-5"
      },
      {
        "id": "productivity-focus",
        "name": "Productivity & Focus Agent",
        "workspace": "~/.openclaw/workspace-productivity",
        "model": "anthropic/claude-sonnet-4-5"
      },
      {
        "id": "emotional-wellness",
        "name": "Emotional Wellness Agent",
        "workspace": "~/.openclaw/workspace-emotional",
        "model": "anthropic/claude-sonnet-4-5"
      },
      {
        "id": "morning-routine",
        "name": "Morning Routine Agent",
        "workspace": "~/.openclaw/workspace-morning",
        "model": "anthropic/claude-sonnet-4-5"
      },
      {
        "id": "departure",
        "name": "Departure Agent",
        "workspace": "~/.openclaw/workspace-departure",
        "model": "anthropic/claude-sonnet-4-5"
      },
      {
        "id": "data-acquisition",
        "name": "Data Acquisition Agent",
        "workspace": "~/.openclaw/workspace-data",
        "model": "anthropic/claude-sonnet-4-5",
        "tools": {
          "camera": { "enabled": true }
        }
      }
    ]
  },
  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": [
        "master-habit",
        "health-fitness",
        "nutrition-diet",
        "sleep-rest",
        "social-communication",
        "entertainment-leisure",
        "learning-education",
        "finance-shopping",
        "home-environment",
        "transportation-travel",
        "personal-care",
        "productivity-focus",
        "emotional-wellness",
        "morning-routine",
        "departure",
        "data-acquisition"
      ]
    },
    "browser": {
      "enabled": true,
      "headless": true
    },
    "exec": {
      "enabled": true,
      "timeout": 30000
    },
    "camera": {
      "enabled": true,
      "clipDuration": 10
    },
    "web": {
      "enabled": true
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    },
    "telegram": {
      "enabled": true,
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    },
    "discord": {
      "enabled": false,
      "comment": "Set to true and configure bot token to enable"
    },
    "slack": {
      "enabled": false,
      "comment": "Set to true and configure app credentials to enable"
    },
    "imessage": {
      "enabled": false,
      "comment": "macOS only - requires imsg CLI"
    }
  },
  "bindings": [
    {
      "agentId": "master-habit",
      "match": { "channel": "whatsapp" }
    },
    {
      "agentId": "master-habit",
      "match": { "channel": "telegram" }
    },
    {
      "agentId": "master-habit",
      "match": { "channel": "discord" }
    }
  ],
  "messages": {
    "groupChat": {
      "mentionPatterns": ["@openclaw", "@lifelog", "@assistant"]
    }
  },
  "providers": {
    "anthropic": {
      "enabled": true,
      "models": ["claude-sonnet-4-5", "claude-sonnet-4-20250514"]
    },
    "openai": {
      "enabled": true,
      "models": ["gpt-4o", "gpt-4o-mini"]
    },
    "openrouter": {
      "enabled": false,
      "comment": "Set API key to enable"
    }
  },
  "skills": {
    "enabled": true,
    "autoLoad": true,
    "directory": "~/.openclaw/skills"
  },
  "plugins": {
    "enabled": true,
    "directory": "~/.openclaw/plugins"
  },
  "webhooks": {
    "enabled": true,
    "endpoints": []
  },
  "sessions": {
    "pruning": {
      "enabled": true,
      "maxAge": "7d",
      "maxCount": 100
    }
  },
  "gateway": {
    "port": 18789,
    "canvasHost": {
      "port": 18793
    }
  }
}
